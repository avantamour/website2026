---
import BaseLayout from './BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import FAQ from '@components/content/FAQ.astro';
import Tag from '@components/ui/Tag.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { formatDate, readingTime } from '@lib/utils';

interface Props {
  entry: CollectionEntry<'insights'>;
}
const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const minutes = readingTime(entry.body);

const allGlossary = await getCollection('glossary', ({ data }) => !data.draft);
const glossaryMap = new Map(allGlossary.map((g) => [g.slug, g]));
const relatedTerms = (d.glossaryRefs ?? [])
  .map((slug) => glossaryMap.get(slug))
  .filter((e): e is CollectionEntry<'glossary'> => Boolean(e));

const allInsights = await getCollection('insights', ({ data }) => !data.draft);
const insightsMap = new Map(allInsights.map((p) => [p.slug, p]));
const relatedReading = (d.relatedPosts ?? [])
  .map((slug) => insightsMap.get(slug))
  .filter((e): e is CollectionEntry<'insights'> => Boolean(e) && e!.slug !== entry.slug);
---
<BaseLayout
  title={d.title}
  description={d.description}
  ogType="article"
  ogImage={d.ogImage}
  publishedTime={d.publishDate.toISOString()}
  modifiedTime={(d.updatedDate ?? d.publishDate).toISOString()}
  jsonLdType="article"
  jsonLdProps={{
    articleHeadline: d.title,
    articleDescription: d.description,
    articleDatePublished: d.publishDate.toISOString(),
    articleDateModified: (d.updatedDate ?? d.publishDate).toISOString(),
    articleImage: d.ogImage,
  }}
  faqs={d.faqs}
>
  <section class="bg-cream pt-12 md:pt-16 pb-10 md:pb-14 border-b border-border">
    <Container>
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Insights', href: '/insights' },
        { label: d.title },
      ]} />
      <p class="eyebrow text-teal mt-6">Notes from the field</p>
      <h1 class="mt-4 font-display font-medium text-h1 md:text-[3rem] leading-[1.1] tracking-tightest text-ink max-w-4xl">
        {d.title}
      </h1>
      <p class="mt-6 text-small text-ink-soft">
        {d.author} · {formatDate(d.publishDate)} · {minutes} min read
      </p>
    </Container>
  </section>

  <section class="bg-paper pt-8 md:pt-12 pb-12 md:pb-20">
    <Container>
      <article class="prose-aa">
        <Content />
      </article>
      <FAQ faqs={d.faqs} />

      {relatedTerms.length > 0 && (
        <aside class="mt-14 md:mt-20 border-t border-border pt-8 md:pt-10" aria-labelledby="related-terms-heading">
          <Eyebrow>Glossary</Eyebrow>
          <h2 id="related-terms-heading" class="font-display font-medium text-h2 md:text-[1.75rem] leading-snug text-ink mb-5">
            Related terms
          </h2>
          <ul class="flex flex-wrap gap-3">
            {relatedTerms.map((t) => (
              <li><Tag href={`/glossary/${t.slug}`}>{t.data.title}</Tag></li>
            ))}
          </ul>
        </aside>
      )}

      {relatedReading.length > 0 && (
        <aside class="mt-14 md:mt-20 border-t border-border pt-8 md:pt-10" aria-labelledby="related-reading-heading">
          <Eyebrow>From the field</Eyebrow>
          <h2 id="related-reading-heading" class="font-display font-medium text-h2 md:text-[1.75rem] leading-snug text-ink mb-6">
            Related reading
          </h2>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {relatedReading.map((p) => (
              <li>
                <a href={`/insights/${p.slug}`} class="block border border-border bg-paper p-6 no-underline hover:border-teal transition-colors h-full">
                  <p class="text-small text-ink-soft">{formatDate(p.data.publishDate)}</p>
                  <h3 class="mt-2 font-display font-medium text-h3 text-ink leading-snug">{p.data.title}</h3>
                  <p class="mt-3 text-small text-ink-soft">{p.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </Container>
  </section>
</BaseLayout>
