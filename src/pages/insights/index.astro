---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { formatDate, readingTime } from '@lib/utils';

const posts = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---
<BaseLayout
  title="Insights"
  description="Notes from the field: essays on ethnography, qualitative research, and Indian consumer behaviour from Arrpita."
>
  <section class="bg-cream pt-12 md:pt-16 pb-10 md:pb-14 border-b border-border">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Insights' }]} />
      <p class="eyebrow text-teal mt-6">Insights</p>
      <h1 class="mt-4 font-display font-medium text-h1 md:text-[3rem] leading-[1.1] tracking-tightest text-ink max-w-3xl">
        Notes from the field.
      </h1>
      <p class="mt-6 text-body text-ink-soft max-w-prose">
        Essays on ethnography, qualitative research, and the patterns we keep seeing in Indian consumer behaviour.
      </p>
    </Container>
  </section>

  <section class="bg-paper py-12 md:py-20">
    <Container>
      <ul class="divide-y divide-border">
        {posts.map((p) => (
          <li class="py-8 first:pt-0">
            <a href={`/insights/${p.slug}`} class="block no-underline group">
              <p class="text-small text-ink-soft">
                {formatDate(p.data.publishDate)} · {readingTime(p.body)} min read
              </p>
              <h2 class="mt-2 font-display font-medium text-h2 leading-[1.15] text-ink group-hover:text-teal transition-colors">
                {p.data.title}
              </h2>
              <p class="mt-3 text-body text-ink-soft max-w-3xl">{p.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>
</BaseLayout>
