---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Services"
  description="Qualitative market research for D2C and digital-first brands in India — ethnography, in-depth interviews, WhatsApp diary studies, UX research, and selective focus-group work, all led by the founder."
>
  <section class="bg-cream pt-12 md:pt-16 pb-10 md:pb-14 border-b border-border">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Services' }]} />
      <p class="eyebrow text-teal mt-6">Services</p>
      <h1 class="mt-4 font-display font-medium text-h1 md:text-[3rem] leading-[1.1] tracking-tightest text-ink max-w-3xl">
        Methods that match the question.
      </h1>
      <p class="mt-6 text-body text-ink-soft max-w-prose">
        Avant Amour is a qualitative market research partner for D2C and digital-first brands. Ethnography is the spine; the other methods extend it. Every engagement is led end-to-end by Arrpita.
      </p>
    </Container>
  </section>

  <section class="bg-paper py-12 md:py-20">
    <Container>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug}`} class="block border border-border bg-paper p-8 no-underline hover:border-teal transition-colors h-full">
              <p class="eyebrow text-teal">{s.data.featured ? 'Primary' : 'Method'}</p>
              <h2 class="mt-3 font-display font-medium text-h2 leading-[1.15] text-ink">{s.data.title}</h2>
              <p class="mt-3 text-body text-ink-soft">{s.data.summary ?? s.data.description}</p>
              <p class="mt-6 text-small font-medium text-teal underline underline-offset-4">Learn more →</p>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>
</BaseLayout>
