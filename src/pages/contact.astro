---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import { BRAND } from '@lib/constants';
---
<BaseLayout
  title="Contact"
  description="Tell us about the question keeping you up at night. We reply within two working days."
>
  <section class="bg-cream pt-12 md:pt-16 pb-10 md:pb-14 border-b border-border">
    <Container>
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
      <p class="eyebrow text-teal mt-6">Get in touch</p>
      <h1 class="mt-4 font-display font-medium text-h1 md:text-[3rem] leading-[1.1] tracking-tightest text-ink max-w-3xl">
        Tell us about the question <span class="yellow-underline">keeping you up</span> at night.
      </h1>
      <p class="mt-6 text-body text-ink-soft max-w-prose">
        We're a qualitative market research firm based in Delhi and Kolkata, working with D2C and digital-first brands across India. We reply within two working days. If ethnography is not the right method for your question, we will say so on the first call.
      </p>
    </Container>
  </section>

  <section id="contact-section" class="bg-paper py-12 md:py-20">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <form
          id="contact-form"
          name="contact"
          method="POST"
          action="/thank-you/"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="lg:col-span-7 space-y-6"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
          <div>
            <label for="name" class="block text-small font-medium mb-2">Your name</label>
            <input id="name" name="name" type="text" required class="w-full border border-border bg-cream px-4 py-3 text-body focus:outline-none focus:border-teal" autocomplete="name" />
          </div>
          <div>
            <label for="email" class="block text-small font-medium mb-2">Email</label>
            <input id="email" name="email" type="email" required class="w-full border border-border bg-cream px-4 py-3 text-body focus:outline-none focus:border-teal" autocomplete="email" />
          </div>
          <div>
            <label for="company" class="block text-small font-medium mb-2">Company</label>
            <input id="company" name="company" type="text" class="w-full border border-border bg-cream px-4 py-3 text-body focus:outline-none focus:border-teal" autocomplete="organization" />
          </div>
          <div>
            <label for="message" class="block text-small font-medium mb-2">What's the question?</label>
            <textarea id="message" name="message" rows="6" required class="w-full border border-border bg-cream px-4 py-3 text-body focus:outline-none focus:border-teal"></textarea>
          </div>
          <button type="submit" class="inline-flex items-center bg-teal text-cream px-6 py-3 font-medium hover:bg-teal-600">
            Send →
          </button>
          <p class="text-small text-ink-soft">
            We use your details only to respond to your enquiry. We don't share them, and we delete enquiry data once it's no longer needed.
          </p>
        </form>

        <aside class="lg:col-span-5 space-y-8">
          <div class="border border-border bg-cream p-6 md:p-8">
            <p class="eyebrow text-teal">Direct</p>
            <p class="mt-3 font-display text-h2 text-ink">
              <a href={`mailto:${BRAND.email}`}>{BRAND.email}</a>
            </p>
            <p class="mt-2 text-body text-ink">
              <a href={`tel:${BRAND.phone.replace(/[^+\d]/g, '')}`} class="no-underline hover:underline">{BRAND.phone}</a>
            </p>
            <p class="mt-2 text-body text-ink">
              <a href={BRAND.whatsapp} target="_blank" rel="noopener noreferrer" class="no-underline hover:underline">Chat on WhatsApp →</a>
            </p>
            <p class="mt-3 text-small text-ink-soft uppercase tracking-eyebrow">{BRAND.locations.join(' · ')}</p>
            <p class="mt-3 text-small text-ink-soft">For project enquiries, partnerships, or a quick "is this the right method for me" call.</p>
            <p class="mt-4 text-small text-ink-soft">
              Avant Amour is ISO/IEC 27001:2022 and ISO 9001:2015 certified.
              Certificate details on request.
            </p>
          </div>
          <div class="border border-border bg-cream p-6 md:p-8">
            <p class="eyebrow text-teal">Book a 30-min call</p>
            <!-- PLACEHOLDER: Arrpita will add Calendly link. -->
            <p class="mt-3 text-body text-ink-soft">Calendly link coming soon. In the meantime, email us and we'll find a slot.</p>
          </div>
          <div>
            <p class="eyebrow text-ink-soft mb-2">Follow</p>
            <ul class="space-y-1 text-small">
              <li><a href={BRAND.social.linkedin} rel="noopener noreferrer" target="_blank">Avant Amour on LinkedIn</a></li>
              <li><a href={BRAND.founder.linkedin} rel="noopener noreferrer" target="_blank">{BRAND.founder.firstName} on LinkedIn</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <script is:inline>
    (function () {
      var section = document.getElementById('contact-section');
      if (!section) return;
      section.querySelectorAll('a[href^="mailto:"]').forEach(function (a) {
        a.addEventListener('click', function () {
          if (typeof gtag === 'function') gtag('event', 'contact_email');
        });
      });
    })();
  </script>
</BaseLayout>
