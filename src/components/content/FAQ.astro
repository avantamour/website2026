---
import Eyebrow from '@components/ui/Eyebrow.astro';

export interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  faqs: FAQItem[];
  eyebrow?: string;
  heading?: string;
  class?: string;
}
const {
  faqs,
  eyebrow = 'Q&A',
  heading = 'Frequently asked questions',
  class: className = '',
} = Astro.props;
---
{faqs && faqs.length > 0 && (
  <section class:list={['not-prose mt-14 md:mt-20', className]} aria-labelledby="faq-heading">
    <Eyebrow>{eyebrow}</Eyebrow>
    <h2 id="faq-heading" class="font-display font-medium text-h1 md:text-[2.25rem] leading-[1.15] tracking-tightest text-ink mb-6 md:mb-10">
      {heading}
    </h2>
    <div class="border-y border-border">
      {faqs.map((f) => (
        <details class="faq-item group border-b border-border last:border-b-0">
          <summary class="flex items-start justify-between gap-6 cursor-pointer list-none py-5 md:py-6">
            <span class="font-display font-medium text-h3 md:text-h2 text-ink leading-snug">
              {f.question}
            </span>
            <span aria-hidden="true" class="faq-indicator shrink-0 mt-1 text-teal text-2xl leading-none w-6 text-center select-none">+</span>
          </summary>
          <div class="pb-6 md:pb-8 pr-0 md:pr-12 text-body text-ink-soft max-w-prose">
            {f.answer}
          </div>
        </details>
      ))}
    </div>
  </section>
)}

<style>
  .faq-item > summary::-webkit-details-marker { display: none; }
  .faq-item[open] .faq-indicator { transform: rotate(45deg); }
  .faq-indicator { transition: transform 160ms ease; transform-origin: center; }
  @media (prefers-reduced-motion: reduce) {
    .faq-indicator { transition: none; }
  }
</style>
