---
import { BRAND } from '@lib/constants';
---
<a
  href={BRAND.whatsapp}
  target="_blank"
  rel="noopener noreferrer"
  class="wa-fab"
  aria-label="Chat with Avant Amour on WhatsApp"
  title="Chat on WhatsApp"
>
  <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor" aria-hidden="true" focusable="false">
    <path d="M16.04 4C9.93 4 4.98 8.95 4.98 15.06c0 1.96.51 3.87 1.49 5.56L4.9 27.1l6.64-1.55a11.04 11.04 0 0 0 4.5.96h.01c6.1 0 11.06-4.95 11.06-11.06 0-2.96-1.15-5.74-3.24-7.83A11 11 0 0 0 16.04 4Zm0 20.27h-.01a9.2 9.2 0 0 1-4.68-1.28l-.34-.2-3.94.92.84-3.84-.22-.36a9.16 9.16 0 0 1-1.4-4.86c0-5.07 4.13-9.2 9.2-9.2 2.46 0 4.77.96 6.5 2.7a9.13 9.13 0 0 1 2.69 6.5c0 5.07-4.12 9.2-9.2 9.2Zm5.05-6.89c-.28-.14-1.64-.81-1.89-.9-.25-.09-.43-.14-.62.14-.18.27-.71.9-.87 1.08-.16.18-.32.2-.6.07-.28-.14-1.17-.43-2.22-1.37-.82-.73-1.38-1.64-1.54-1.91-.16-.28-.02-.43.12-.57.13-.13.28-.32.41-.49.14-.16.18-.27.28-.46.09-.18.05-.34-.02-.48-.07-.14-.62-1.5-.85-2.05-.22-.54-.45-.46-.62-.47-.16-.01-.34-.01-.53-.01-.18 0-.48.07-.73.34-.25.27-.96.94-.96 2.3s.98 2.66 1.12 2.85c.14.18 1.93 2.95 4.68 4.13.65.28 1.16.45 1.56.58.65.21 1.25.18 1.72.11.52-.08 1.64-.67 1.87-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.18-.53-.32Z"/>
  </svg>
</a>
<style>
  .wa-fab {
    position: fixed; right: 1.25rem; bottom: 1.25rem; z-index: 60;
    display: inline-flex; align-items: center; justify-content: center;
    width: 4rem; height: 4rem; border-radius: 9999px;
    background: #25D366; color: #fff;
    box-shadow: 0 6px 20px rgba(0,0,0,0.18);
    transition: transform 150ms ease, box-shadow 150ms ease;
  }
  .wa-fab:hover { transform: translateY(-2px); box-shadow: 0 10px 26px rgba(0,0,0,0.24); }
  .wa-fab:focus-visible { outline: 3px solid #1A9FA5; outline-offset: 2px; }
  @media (max-width: 640px) {
    .wa-fab { right: 1rem; bottom: 1rem; width: 3.5rem; height: 3.5rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-fab { transition: none; } .wa-fab:hover { transform: none; }
  }
  @keyframes wa-pulse {
    0%   { box-shadow: 0 6px 20px rgba(0,0,0,0.18), 0 0 0 0 rgba(37,211,102,0.55); }
    70%  { box-shadow: 0 6px 20px rgba(0,0,0,0.18), 0 0 0 18px rgba(37,211,102,0); }
    100% { box-shadow: 0 6px 20px rgba(0,0,0,0.18), 0 0 0 0 rgba(37,211,102,0); }
  }
  .wa-fab {
    animation: wa-pulse 2s ease-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-fab { animation: none; }
  }
</style>
