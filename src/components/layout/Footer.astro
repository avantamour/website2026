---
import Container from '@components/ui/Container.astro';
import { BRAND, FOOTER_LINKS } from '@lib/constants';
const year = new Date().getFullYear();
---
<footer class="bg-paper border-t border-border mt-16">
  <Container class="py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3 no-underline">
          <img
            src="/logo-mark.png"
            alt="Avant Amour"
            width="385"
            height="400"
            class="h-12 w-auto shrink-0"
            loading="lazy"
            decoding="async"
          />
          <span class="font-display text-h2 text-ink leading-none">{BRAND.name}</span>
        </a>
        <p class="mt-4 max-w-sm text-small text-ink-soft">{BRAND.subLine}</p>
        <p class="mt-6 text-small">
          <a href={`mailto:${BRAND.email}`}>{BRAND.email}</a>
        </p>
      </div>

      <div class="md:col-span-2">
        <p class="eyebrow mb-3">Explore</p>
        <ul class="space-y-2 text-small">
          {FOOTER_LINKS.explore.map((l) => (
            <li><a href={l.href} class="text-ink hover:text-teal no-underline">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <p class="eyebrow mb-3">Company</p>
        <ul class="space-y-2 text-small">
          {FOOTER_LINKS.company.map((l) => (
            <li><a href={l.href} class="text-ink hover:text-teal no-underline">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-4">
        <h3 class="eyebrow text-teal">Certifications</h3>
        <ul class="not-prose list-none p-0 m-0 mt-3 space-y-2 text-small text-ink-soft">
          {BRAND.certifications.map((c) => (
            <li>
              <span class="text-ink font-medium">{c.standard}</span>
              <span class="block text-ink-soft">{c.scope}</span>
            </li>
          ))}
          <li class="text-ink-soft">
            Certified by EAS · IAF-accredited<br />
            Valid through January 2029
          </li>
        </ul>
      </div>
    </div>

    <hr class="my-10" />

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-small text-ink-soft">
      <p>© {year} {BRAND.name}. {BRAND.audience}.</p>
      <p>
        <a href={BRAND.founder.linkedin} rel="noopener noreferrer" target="_blank">LinkedIn</a>
      </p>
    </div>
  </Container>
</footer>
<script is:inline>
  (function () {
    var footer = document.querySelector('footer');
    if (!footer) return;
    footer.querySelectorAll('a[href^="mailto:"]').forEach(function (a) {
      a.addEventListener('click', function () {
        if (typeof gtag === 'function') gtag('event', 'contact_email');
      });
    });
  })();
</script>
