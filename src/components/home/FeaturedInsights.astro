---
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '@lib/utils';

const posts = (await getCollection('insights', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---
<Section background="paper">
  <Container>
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div>
        <Eyebrow>Latest writing</Eyebrow>
        <h2 class="font-display font-medium text-h1 md:text-[2.5rem] leading-[1.1] tracking-tightest text-ink max-w-2xl">
          Notes from the field.
        </h2>
      </div>
      <a href="/insights" class="text-small font-medium text-teal no-underline hover:underline underline-offset-4">All posts →</a>
    </div>

    <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {posts.map((p) => (
        <a href={`/insights/${p.slug}`} class="no-underline block border border-border bg-paper p-6 transition-colors hover:border-teal">
          <p class="eyebrow text-ink-soft">{formatDate(p.data.publishDate)}</p>
          <h3 class="mt-3 font-display font-medium text-h3 leading-[1.2] text-ink">{p.data.title}</h3>
          <p class="mt-3 text-small text-ink-soft">{p.data.description}</p>
          <p class="mt-5 text-small font-medium text-teal underline underline-offset-4">Read →</p>
        </a>
      ))}
    </div>
  </Container>
</Section>
