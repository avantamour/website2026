---
import Container from '@components/ui/Container.astro';
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';

const steps = [
  { n: '01', t: 'Listen', d: 'We start with the business question, not the method. What decision is this research about to inform?' },
  { n: '02', t: 'Observe', d: 'We meet customers in their setting — homes, clinics, autos, WhatsApp threads. Behaviour first, opinion second.' },
  { n: '03', t: 'Interpret', d: 'We connect observations to patterns. The output is a clear point of view, not a transcript dump.' },
  { n: '04', t: 'Activate', d: 'We sit with your team to convert findings into product, positioning, and pricing moves you can ship.' },
];
---
<Section background="cream">
  <Container>
    <Eyebrow>How we work</Eyebrow>
    <h2 class="font-display font-medium text-h1 md:text-[2.5rem] leading-[1.1] tracking-tightest text-ink max-w-2xl">
      A four-step engagement, run by the founder herself.
    </h2>

    <ol class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {steps.map((s, i) => (
        <li class="relative border-t border-border pt-6">
          <span class="block font-display text-h3 text-teal">{s.n}</span>
          <h3 class="mt-2 font-display font-medium text-h2 text-ink">{s.t}</h3>
          <p class="mt-3 text-small text-ink-soft">{s.d}</p>
          {i === 0 && <span aria-hidden="true" class="absolute -top-[3px] left-0 w-12 h-[3px] bg-yellow"></span>}
        </li>
      ))}
    </ol>
  </Container>
</Section>
