---
import { BRAND } from '@lib/constants';
import { absoluteUrl, truncate } from '@lib/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = BRAND.defaultDescription,
  ogImage = '/og-default.jpg',
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
} = Astro.props;

const pageTitle = title === BRAND.name ? BRAND.name : `${title} | ${BRAND.name}`;
const desc = truncate(description, 160);
const canonical = absoluteUrl(Astro.url.pathname, BRAND.url);
const ogImageUrl = absoluteUrl(ogImage, BRAND.url);
---
<title>{pageTitle}</title>
<meta name="description" content={desc} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="author" content={BRAND.founder.firstName} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={BRAND.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={desc} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Avant Amour — ethnographic consumer research for D2C brands" />
<meta property="og:locale" content="en_IN" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={desc} />
<meta name="twitter:image" content={ogImageUrl} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" href="/logo.png" />
<link rel="alternate" type="application/rss+xml" title={`${BRAND.name} — Insights`} href="/rss.xml" />
